{
  "project": {
    "name": "My Fantastic Project",
    "subtitle": "负责人统筹 · 子任务并行 · 统一验收",
    "root": "/absolute/path/to/your/project",
    "manager_thread_id": "optional-lead-thread-id"
  },
  "discovery": {
    "workspace_match": "/absolute/path/to/your/project",
    "include_archived": false,
    "title_keywords": [],
    "exclude_title_patterns": []
  },
  "roles": {
    "optional-lead-thread-id": {
      "id": "lead",
      "name": "项目负责人",
      "assignment": "项目规划、依赖协调与统一验收"
    },
    "optional-product-thread-id": {
      "id": "product",
      "name": "产品负责人",
      "assignment": "用户需求、产品优先级与迭代复盘"
    }
  },
  "artifacts": {
    "allowed_roots": [
      "/absolute/path/to/your/project"
    ],
    "remote_prefixes": [
      "/home/",
      "/workspace/"
    ],
    "ignore_contains": [
      "/tmp/",
      "/.cache/",
      "/node_modules/",
      "/site-packages/"
    ],
    "max_per_task": 8
  },
  "secretary": {
    "enabled": true,
    "cache": "/absolute/path/to/your/project/.pixelcrew/secretary.json",
    "max_age_minutes": 180
  }
}
